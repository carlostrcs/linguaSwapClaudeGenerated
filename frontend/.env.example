# Copy to .env.local for local overrides, or set these in your host's dashboard (Vercel).
# Vite only exposes variables prefixed with VITE_, and inlines them at BUILD time —
# changing this requires a rebuild, not just a restart.

# Base URL of the API, including the /api suffix.
# Leave unset locally: the client falls back to http://localhost:5299/api (see src/api/client.ts).
# Production example:
# VITE_API_URL=https://linguaswap-api.onrender.com/api
