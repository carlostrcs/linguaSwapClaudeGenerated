{
  "name": "Slang & Idioms",
  "description": "Sound like a local — common colloquial words and idioms with their natural equivalents in each language (English, Spanish, French, German, Italian, Portuguese).",
  "entries": [
    { "translations": { "en": "cool", "es": "guay", "fr": "cool", "de": "cool", "it": "figo", "pt": "fixe" }, "notes": "Informal way to say 'great / nice'." },
    { "translations": { "en": "awesome", "es": "genial", "fr": "génial", "de": "super", "it": "fantastico", "pt": "espetacular" }, "notes": "Very good, excellent." },
    { "translations": { "en": "guy / dude", "es": "tío", "fr": "mec", "de": "Typ", "it": "tizio", "pt": "gajo" }, "notes": "Informal word for a man/guy." },
    { "translations": { "en": "to hang out", "es": "pasar el rato", "fr": "traîner", "de": "abhängen", "it": "passare il tempo", "pt": "passar o tempo" }, "notes": "To spend time casually." },
    { "translations": { "en": "to chill / relax", "es": "relajarse", "fr": "se détendre", "de": "chillen", "it": "rilassarsi", "pt": "relaxar" }, "notes": "To take it easy." },
    { "translations": { "en": "No way!", "es": "¡Ni hablar!", "fr": "Pas question !", "de": "Auf keinen Fall!", "it": "Neanche per sogno!", "pt": "Nem pensar!" }, "notes": "Absolutely not." },
    { "translations": { "en": "Awesome, right?", "es": "¿A que mola?", "fr": "C'est top, non ?", "de": "Cool, oder?", "it": "Forte, vero?", "pt": "Fixe, não é?" }, "notes": "Informal 'isn't that great?'." },
    { "translations": { "en": "It's a piece of cake", "es": "es pan comido", "fr": "c'est du gâteau", "de": "das ist ein Kinderspiel", "it": "è un gioco da ragazzi", "pt": "é canja" }, "notes": "It's very easy." },
    { "translations": { "en": "It's raining cats and dogs", "es": "está lloviendo a cántaros", "fr": "il pleut des cordes", "de": "es regnet in Strömen", "it": "piove a catinelle", "pt": "está a chover a cântaros" }, "notes": "It's raining very hard." },
    { "translations": { "en": "to cost an arm and a leg", "es": "costar un ojo de la cara", "fr": "coûter les yeux de la tête", "de": "ein Vermögen kosten", "it": "costare un occhio della testa", "pt": "custar os olhos da cara" }, "notes": "To be very expensive." },
    { "translations": { "en": "to pull someone's leg", "es": "tomar el pelo", "fr": "faire marcher quelqu'un", "de": "jemanden auf den Arm nehmen", "it": "prendere in giro", "pt": "gozar com alguém" }, "notes": "To tease or joke with someone." },
    { "translations": { "en": "to be broke", "es": "estar sin blanca", "fr": "être fauché", "de": "pleite sein", "it": "essere al verde", "pt": "estar teso" }, "notes": "To have no money." },
    { "translations": { "en": "Speak of the devil", "es": "hablando del rey de Roma", "fr": "quand on parle du loup", "de": "wenn man vom Teufel spricht", "it": "parli del diavolo", "pt": "falar no diabo" }, "notes": "Said when someone you were talking about appears." },
    { "translations": { "en": "not my cup of tea", "es": "no es lo mío", "fr": "ce n'est pas ma tasse de thé", "de": "nicht mein Ding", "it": "non fa per me", "pt": "não é a minha praia" }, "notes": "Not something I enjoy." },
    { "translations": { "en": "to hit the nail on the head", "es": "dar en el clavo", "fr": "mettre le doigt dessus", "de": "den Nagel auf den Kopf treffen", "it": "colpire nel segno", "pt": "acertar em cheio" }, "notes": "To be exactly right." },
    { "translations": { "en": "Good luck! (break a leg)", "es": "¡mucha suerte!", "fr": "bonne chance !", "de": "Hals- und Beinbruch!", "it": "in bocca al lupo!", "pt": "boa sorte!" }, "notes": "Wishing someone luck." },
    { "translations": { "en": "little by little", "es": "poco a poco", "fr": "petit à petit", "de": "nach und nach", "it": "poco a poco", "pt": "pouco a pouco" }, "notes": "Gradually." },
    { "translations": { "en": "more or less", "es": "más o menos", "fr": "plus ou moins", "de": "mehr oder weniger", "it": "più o meno", "pt": "mais ou menos" }, "notes": "Approximately." },
    { "translations": { "en": "What a mess!", "es": "¡Qué lío!", "fr": "Quel bazar !", "de": "Was für ein Chaos!", "it": "Che casino!", "pt": "Que confusão!" }, "notes": "A chaotic situation." },
    { "translations": { "en": "Are you kidding?", "es": "¿En serio?", "fr": "Tu rigoles ?", "de": "Machst du Witze?", "it": "Stai scherzando?", "pt": "Estás a brincar?" }, "notes": "Expressing disbelief." },
    { "translations": { "en": "no worries", "es": "tranqui", "fr": "t'inquiète", "de": "kein Ding", "it": "tranquillo", "pt": "não faz mal" }, "notes": "Informal 'don't worry'." },
    { "translations": { "en": "awesome time", "es": "un pasada", "fr": "un moment génial", "de": "eine super Zeit", "it": "uno spasso", "pt": "uma curtição" }, "notes": "A really great time." },
    { "translations": { "en": "to be fed up", "es": "estar harto", "fr": "en avoir marre", "de": "die Nase voll haben", "it": "essere stufo", "pt": "estar farto" }, "notes": "To be tired of something." },
    { "translations": { "en": "on the dot (exactly)", "es": "en punto", "fr": "pile", "de": "auf die Minute", "it": "in punto", "pt": "em ponto" }, "notes": "Exactly on time." },
    { "translations": { "en": "big deal / a lot", "es": "un montón", "fr": "plein", "de": "eine Menge", "it": "un sacco", "pt": "um monte" }, "notes": "A large amount." },
    { "translations": { "en": "to mess up", "es": "meter la pata", "fr": "faire une gaffe", "de": "Mist bauen", "it": "fare una gaffe", "pt": "dar uma bronca" }, "notes": "To make a mistake." },
    { "translations": { "en": "step by step", "es": "paso a paso", "fr": "pas à pas", "de": "Schritt für Schritt", "it": "passo dopo passo", "pt": "passo a passo" }, "notes": "Gradually, in stages." },
    { "translations": { "en": "It's worth it", "es": "vale la pena", "fr": "ça vaut le coup", "de": "es lohnt sich", "it": "ne vale la pena", "pt": "vale a pena" }, "notes": "It is worthwhile." },
    { "translations": { "en": "so-so", "es": "así así", "fr": "comme ci comme ça", "de": "so lala", "it": "così così", "pt": "mais ou menos" }, "notes": "Neither good nor bad." },
    { "translations": { "en": "to keep an eye on", "es": "echar un ojo", "fr": "garder un œil", "de": "ein Auge behalten", "it": "tenere d'occhio", "pt": "ficar de olho" }, "notes": "To watch/monitor something." },
    { "translations": { "en": "Get it? / Understood?", "es": "¿Vale?", "fr": "D'accord ?", "de": "Alles klar?", "it": "Chiaro?", "pt": "Percebeste?" }, "notes": "Checking understanding." },
    { "translations": { "en": "Okay / alright", "es": "vale", "fr": "d'accord", "de": "okay", "it": "va bene", "pt": "está bem" }, "notes": "Agreement." },
    { "translations": { "en": "to be worth nothing", "es": "no valer nada", "fr": "ne rien valoir", "de": "nichts taugen", "it": "non valere niente", "pt": "não valer nada" }, "notes": "To be worthless." },
    { "translations": { "en": "hurry up!", "es": "¡date prisa!", "fr": "dépêche-toi !", "de": "beeil dich!", "it": "sbrigati!", "pt": "despacha-te!" }, "notes": "Telling someone to be quick." },
    { "translations": { "en": "to be in a hurry", "es": "tener prisa", "fr": "être pressé", "de": "es eilig haben", "it": "avere fretta", "pt": "ter pressa" }, "notes": "To need to hurry." },
    { "translations": { "en": "for real / seriously", "es": "en serio", "fr": "sérieux", "de": "im Ernst", "it": "sul serio", "pt": "a sério" }, "notes": "Genuinely." },
    { "translations": { "en": "That's life", "es": "así es la vida", "fr": "c'est la vie", "de": "so ist das Leben", "it": "così è la vita", "pt": "é a vida" }, "notes": "Accepting how things are." },
    { "translations": { "en": "Better late than never", "es": "más vale tarde que nunca", "fr": "mieux vaut tard que jamais", "de": "besser spät als nie", "it": "meglio tardi che mai", "pt": "mais vale tarde do que nunca" }, "notes": "Common proverb." },
    { "translations": { "en": "little by little the bird builds its nest", "es": "poco a poco se llega lejos", "fr": "petit à petit l'oiseau fait son nid", "de": "steter Tropfen höhlt den Stein", "it": "chi va piano va sano e va lontano", "pt": "devagar se vai ao longe" }, "notes": "Patience and persistence pay off." },
    { "translations": { "en": "to be on cloud nine", "es": "estar en las nubes", "fr": "être aux anges", "de": "im siebten Himmel sein", "it": "essere al settimo cielo", "pt": "estar nas nuvens" }, "notes": "To be extremely happy." },
    { "translations": { "en": "to have a green thumb", "es": "tener buena mano", "fr": "avoir la main verte", "de": "einen grünen Daumen haben", "it": "avere il pollice verde", "pt": "ter jeito para as plantas" }, "notes": "To be good with plants." },
    { "translations": { "en": "when pigs fly", "es": "cuando las ranas críen pelo", "fr": "quand les poules auront des dents", "de": "wenn Schweine fliegen könnten", "it": "quando gli asini voleranno", "pt": "no dia de são nunca" }, "notes": "Something that will never happen." },
    { "translations": { "en": "to cost nothing / dirt cheap", "es": "estar tirado de precio", "fr": "ne rien coûter", "de": "spottbillig sein", "it": "costare due soldi", "pt": "estar a preço de saldo" }, "notes": "Very cheap." },
    { "translations": { "en": "no big deal", "es": "no pasa nada", "fr": "ce n'est rien", "de": "kein Problem", "it": "non è un problema", "pt": "não é nada de mais" }, "notes": "It doesn't matter." },
    { "translations": { "en": "to be all ears", "es": "ser todo oídos", "fr": "être tout ouïe", "de": "ganz Ohr sein", "it": "essere tutt'orecchi", "pt": "ser todo ouvidos" }, "notes": "To listen attentively." },
    { "translations": { "en": "wow!", "es": "¡guau!", "fr": "waouh !", "de": "wow!", "it": "wow!", "pt": "uau!" }, "notes": "Expression of surprise." },
    { "translations": { "en": "Come on!", "es": "¡Vamos!", "fr": "Allez !", "de": "Los!", "it": "Dai!", "pt": "Vá lá!" }, "notes": "Encouragement or urging." },
    { "translations": { "en": "What's up?", "es": "¿Qué pasa?", "fr": "Quoi de neuf ?", "de": "Was geht?", "it": "Che si dice?", "pt": "Que se passa?" }, "notes": "Informal greeting." },
    { "translations": { "en": "totally", "es": "totalmente", "fr": "carrément", "de": "total", "it": "assolutamente", "pt": "totalmente" }, "notes": "Complete agreement." },
    { "translations": { "en": "kind of / a bit", "es": "un poco", "fr": "un peu", "de": "irgendwie", "it": "un po'", "pt": "mais ou menos" }, "notes": "Somewhat." },
    { "translations": { "en": "Whatever / I don't care", "es": "lo que sea", "fr": "n'importe quoi", "de": "wie auch immer", "it": "come vuoi", "pt": "tanto faz" }, "notes": "Expressing indifference." },
    { "translations": { "en": "No idea", "es": "ni idea", "fr": "aucune idée", "de": "keine Ahnung", "it": "nessuna idea", "pt": "nem ideia" }, "notes": "I have no clue." },
    { "translations": { "en": "to freak out", "es": "flipar", "fr": "paniquer", "de": "ausflippen", "it": "andare fuori di testa", "pt": "passar-se" }, "notes": "To panic or lose control." },
    { "translations": { "en": "by the way", "es": "por cierto", "fr": "au fait", "de": "übrigens", "it": "a proposito", "pt": "a propósito" }, "notes": "Introducing a side comment." },
    { "translations": { "en": "as usual", "es": "como siempre", "fr": "comme d'habitude", "de": "wie immer", "it": "come al solito", "pt": "como sempre" }, "notes": "The way it always is." },
    { "translations": { "en": "to make sense", "es": "tener sentido", "fr": "avoir du sens", "de": "Sinn ergeben", "it": "avere senso", "pt": "fazer sentido" }, "notes": "To be logical." },
    { "translations": { "en": "to be lucky", "es": "tener suerte", "fr": "avoir de la chance", "de": "Glück haben", "it": "essere fortunato", "pt": "ter sorte" }, "notes": "To have good fortune." },
    { "translations": { "en": "to be unlucky", "es": "tener mala suerte", "fr": "avoir de la malchance", "de": "Pech haben", "it": "essere sfortunato", "pt": "ter azar" }, "notes": "To have bad luck." },
    { "translations": { "en": "to be in a good mood", "es": "estar de buen humor", "fr": "être de bonne humeur", "de": "gute Laune haben", "it": "essere di buon umore", "pt": "estar de bom humor" }, "notes": "Feeling cheerful." },
    { "translations": { "en": "to be in a bad mood", "es": "estar de mal humor", "fr": "être de mauvaise humeur", "de": "schlechte Laune haben", "it": "essere di cattivo umore", "pt": "estar de mau humor" }, "notes": "Feeling grumpy." },
    { "translations": { "en": "It's a deal!", "es": "¡trato hecho!", "fr": "marché conclu !", "de": "abgemacht!", "it": "affare fatto!", "pt": "negócio fechado!" }, "notes": "Agreed / settled." },
    { "translations": { "en": "Take it easy", "es": "tómatelo con calma", "fr": "vas-y doucement", "de": "immer mit der Ruhe", "it": "prendila con calma", "pt": "leva com calma" }, "notes": "Relax, don't rush." },
    { "translations": { "en": "Come on!", "es": "¡venga ya!", "fr": "allez, quoi !", "de": "komm schon!", "it": "ma dai!", "pt": "vá lá!" }, "notes": "Urging or disbelief." },
    { "translations": { "en": "gross / yuck", "es": "qué asco", "fr": "beurk", "de": "igitt", "it": "che schifo", "pt": "que nojo" }, "notes": "Disgusting." },
    { "translations": { "en": "to be exhausted", "es": "estar hecho polvo", "fr": "être crevé", "de": "todmüde sein", "it": "essere distrutto", "pt": "estar de rastos" }, "notes": "Very tired." },
    { "translations": { "en": "What a drag / how boring", "es": "qué rollo", "fr": "quelle galère", "de": "wie nervig", "it": "che noia", "pt": "que seca" }, "notes": "Tedious or annoying." },
    { "translations": { "en": "to nail it", "es": "clavarlo", "fr": "assurer", "de": "es draufhaben", "it": "spaccare", "pt": "arrasar" }, "notes": "To do something very well." },
    { "translations": { "en": "to hit the road", "es": "ponerse en marcha", "fr": "prendre la route", "de": "losfahren", "it": "mettersi in viaggio", "pt": "pôr-se a caminho" }, "notes": "To set off / leave." },
    { "translations": { "en": "to chicken out", "es": "acobardarse", "fr": "se dégonfler", "de": "kneifen", "it": "tirarsi indietro", "pt": "acobardar-se" }, "notes": "To back out from fear." },
    { "translations": { "en": "to be up for it", "es": "apuntarse", "fr": "être partant", "de": "dabei sein", "it": "esserci", "pt": "alinhar" }, "notes": "Willing to join in." },
    { "translations": { "en": "You're kidding!", "es": "¡no me digas!", "fr": "sans blague !", "de": "nicht dein Ernst!", "it": "ma va!", "pt": "não me digas!" }, "notes": "Expressing surprise." },
    { "translations": { "en": "big deal / so what", "es": "¿y qué?", "fr": "et alors ?", "de": "na und?", "it": "e allora?", "pt": "e depois?" }, "notes": "Dismissing something." },
    { "translations": { "en": "That's cool of you", "es": "qué majo eres", "fr": "c'est sympa de ta part", "de": "nett von dir", "it": "gentile da parte tua", "pt": "és simpático" }, "notes": "That's kind of you." },
    { "translations": { "en": "to hang in there", "es": "aguantar", "fr": "tenir bon", "de": "durchhalten", "it": "resistere", "pt": "aguentar" }, "notes": "To persevere." },
    { "translations": { "en": "awesome! (exclamation)", "es": "¡genial!", "fr": "génial !", "de": "spitze!", "it": "fantastico!", "pt": "espetacular!" }, "notes": "Great!" }
  ]
}
